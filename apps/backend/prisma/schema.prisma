// OmoHealth – Prisma Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  IYALOJA
  MEMBER
  CLINIC_ADMIN
}

enum PlanTier {
  BRONZE // ₦500/wk · ₦100k/yr · ₦75k cap/claim
  SILVER // ₦1,000/wk · ₦150k/yr · ₦100k cap/claim
  GOLD   // ₦2,000/wk · ₦300k/yr · ₦200k cap/claim
}

enum MemberStatus {
  ACTIVE
  PAUSED     // opted out via SMS STOP — no debits, no claims
  FLAGGED    // admin-flagged — claims blocked
  INCOMPLETE // BVN returned no phone — wallet not yet created
}

enum ContributionSource {
  DIRECT_DEBIT
  CASH
}

enum ContributionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ClaimStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
  FAILED // hospital transfer bounced — can retry within 24h
}

// ─── Models ───────────────────────────────────────────────────────────────────

/// Central auth table. Everyone who can log in has a User row.
/// Auth is phone + OTP — no passwords.
model User {
  id          String   @id @default(uuid())
  phone       String   @unique
  role        UserRole
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  association Association? // set when role = IYALOJA
  member      Member?      // set when user is also enrolled as a member
  clinicAdmin ClinicAdmin? // set when role = CLINIC_ADMIN

  @@map("users")
}

/// Short-lived OTP for phone-based login. All roles share this table.
model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  code      String   // bcrypt-hashed 6-digit code
  expiresAt DateTime // 5 minutes from creation
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_codes")
}

/// The health pool. Owned by one Iyaloja (User with role = IYALOJA).
/// poolBalance is stored and updated — not computed — for fast reads.
model Association {
  id              String    @id @default(uuid())
  userId          String    @unique // the Iyaloja's User ID
  name                  String
  cacNumber             String?
  plan                  PlanTier  @default(BRONZE)
  monthlyDues           Float?
  coverageLimit         Float?
  poolBalance           Float     @default(0)
  walletId              String?   // Interswitch merchant-wallet walletId for this iyaloja
  walletAccountNumber   String?   // Settlement account number (for receiving payments)
  anniversaryDate DateTime? // coverage resets each year on this date
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  members       Member[]
  contributions Contribution[]
  claims        Claim[]

  @@map("associations")
}

/// A person enrolled in a specific association.
/// One person can appear in multiple associations (separate rows, stacked coverage).
/// userId is optional — Iyaloja enrolls members by BVN; they get a User row
/// only if they log in to check coverage.
model Member {
  id                         String       @id @default(uuid())
  userId                     String?      @unique // optional — set if member has a login
  associationId              String
  bvn                        String
  phone                      String
  name                       String?
  status                     MemberStatus @default(ACTIVE)
  walletId                   String?      // Interswitch merchant-wallet ID for this member
  walletAccountNumber        String?      // Settlement account number (pay dues to this account)
  walletStatus               String       @default("PENDING") // PENDING | PROVISIONING | ACTIVE | FAILED
  coverageUsedThisYear       Float        @default(0)
  consecutiveMissedPayments  Int          @default(0) // flags member to Iyaloja after 3 misses
  optOut                     Boolean      @default(false)
  waitingPeriodStart         DateTime     @default(now())
  enrolledAt                 DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt

  user          User?          @relation(fields: [userId], references: [id])
  association   Association    @relation(fields: [associationId], references: [id])
  wallet        Wallet?
  contributions Contribution[]
  claims        Claim[]

  @@unique([associationId, bvn]) // no duplicate BVN in the same association
  @@map("members")
}

/// Interswitch wallet for a member. Used for weekly direct debit.
/// Only created when member status moves from INCOMPLETE → ACTIVE.
model Wallet {
  id             String   @id @default(uuid())
  memberId       String   @unique
  interswitchRef String   @unique // Interswitch wallet ID
  balance        Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id])

  @@map("wallets")
}

/// One row per weekly debit attempt or manual cash entry.
/// Tracks money IN to the pool.
/// On SUCCESS → Association.poolBalance is incremented.
/// Duplicate check: (memberId, week) must be unique per successful debit.
model Contribution {
  id             String             @id @default(uuid())
  memberId       String
  associationId  String
  amount         Float
  source         ContributionSource @default(DIRECT_DEBIT)
  status         ContributionStatus @default(PENDING)
  interswitchRef String?            // Interswitch debit reference
  week           DateTime           // the Monday this contribution covers
  createdAt      DateTime           @default(now())

  member      Member      @relation(fields: [memberId], references: [id])
  association Association @relation(fields: [associationId], references: [id])

  @@map("contributions")
}

/// Hospital payout. Tracks money OUT of the pool.
/// Flow: PENDING → PAID
///                  ↘ FAILED (hospital transfer bounced)
/// On PAID → Association.poolBalance decremented, Member.coverageUsedThisYear incremented.
model Claim {
  id               String      @id @default(uuid())
  associationId    String
  memberId         String
  clinicId         String?     // which clinic institution (set for portal-submitted claims)
  clinicAdminId    String?     // which clinic admin submitted (set for portal-submitted claims)
  hospitalName     String      // kept for display + manual/legacy claim compatibility
  hospitalAccount  String?     // bank account for Interswitch transfer
  hospitalBankCode String?     // CBN bank code (e.g. "044" for Access Bank)
  billAmount       Float       // what the hospital charged
  approvedAmount   Float?      // capped at plan limit — what the pool pays
  billPhotoUrl     String?     // Cloudinary URL (wired up later)
  status           ClaimStatus @default(PENDING)
  interswitchRef   String?     // Interswitch payment reference
  otpVerified      Boolean     @default(false)
  description      String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  association  Association  @relation(fields: [associationId], references: [id])
  member       Member       @relation(fields: [memberId], references: [id])
  clinic       Clinic?      @relation(fields: [clinicId], references: [id])
  clinicAdmin  ClinicAdmin? @relation(fields: [clinicAdminId], references: [id])

  @@map("claims")
}

/// The clinic as an institution — name, address, bank payout details.
model Clinic {
  id          String  @id @default(uuid())
  name        String
  address     String?
  bankAccount String? // clinic's bank account for direct payouts
  bankCode    String? // CBN bank code
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admins ClinicAdmin[]
  claims Claim[]

  @@map("clinics")
}

/// Join table: which User has access to which Clinic.
model ClinicAdmin {
  id       String @id @default(uuid())
  clinicId String
  userId   String @unique // one user → one clinic for now

  clinic Clinic  @relation(fields: [clinicId], references: [id])
  user   User    @relation(fields: [userId], references: [id])
  claims Claim[]

  @@map("clinic_admins")
}

