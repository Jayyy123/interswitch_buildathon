# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/hackathon_db?schema=public"

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ─── Interswitch ─────────────────────────────────────────────────────────────
INTERSWITCH_CLIENT_ID=your_client_id_here
INTERSWITCH_SECRET_KEY=your_secret_key_here
INTERSWITCH_BASE_URL=https://sandbox.interswitchng.com
INTERSWITCH_PAYMENT_GATEWAY_URL=https://sandbox.interswitchng.com/dpg
