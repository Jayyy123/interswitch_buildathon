# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/hackathon_db?schema=public"

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ─── Interswitch ─────────────────────────────────────────────────────────────
# QTB (payment gateway, web checkout)
INTERSWITCH_CLIENT_ID=your_qtb_client_id
INTERSWITCH_SECRET_KEY=your_qtb_secret_key
INTERSWITCH_MERCHANT_CODE=your_merchant_code
INTERSWITCH_PAY_ITEM_ID=9405967

# Marketplace (BVN lookup token)
INTERSWITCH_MARKETPLACE_CLIENT_ID=your_marketplace_client_id
INTERSWITCH_MARKETPLACE_SECRET_KEY=your_marketplace_secret_key

# BVN dedicated credentials
INTERSWITCH_BVN_CLIENT_ID=your_bvn_client_id
INTERSWITCH_BVN_SECRET_KEY=your_bvn_secret_key

# GI / MX6072 (virtual accounts + merchant wallets)
INTERSWITCH_GI_CLIENT_ID=your_gi_client_id
INTERSWITCH_GI_SECRET_KEY=your_gi_secret_key

# SVA (account name inquiry + fund transfers)
INTERSWITCH_SVA_CLIENT_ID=your_sva_client_id
INTERSWITCH_SVA_SECRET_KEY=your_sva_secret_key
INTERSWITCH_TERMINAL_ID=3PBL0001

# Wallet
INTERSWITCH_WALLET_CLIENT_ID=
INTERSWITCH_WALLET_SECRET_KEY=
INTERSWITCH_WALLET_ID=2700014982
INTERSWITCH_WALLET_PIN=1234

# ─── Termii (SMS) ─────────────────────────────────────────────────────────────
TERMII_API_KEY=your_termii_api_key_here
TERMII_SENDER_ID=OmoHealth
TERMII_BASE_URL=https://api.ng.termii.com
